{
  "name": "finance-mate",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api:dev": "npm run dev --workspace apps/api",
    "api:build": "npm run build --workspace apps/api",
    "api:typecheck": "npm run typecheck --workspace apps/api",
    "api:test": "npm run test --workspace apps/api",
    "api:prisma:migrate": "npm run prisma:migrate --workspace apps/api",
    "api:prisma:seed": "npm run prisma:seed --workspace apps/api",
    "mobile:start": "npm run start --workspace apps/mobile",
    "mobile:typecheck": "npm run typecheck --workspace apps/mobile"
  },
  "engines": {
    "node": ">=18"
  }
}
